<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Dịch Vụ Ăn Uống</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
        }

        body {
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
            padding-top: 60px;
        }

        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

        .main-container {
            flex: 1;
            padding: 20px 0;
        }

        .card {
            border: none;
        }

        footer {
            margin-top: auto;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-danger" asp-controller="Home" asp-action="Index">
                🍽️ HUIT Food
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- Search Bar Integrated in Navbar -->
                <div class="mx-auto" style="max-width: 500px; width: 100%;">
                    <form asp-controller="Home" asp-action="Filter" method="get" class="d-flex position-relative" id="mainSearchForm">
                        <div class="input-group">
                            <input type="text" name="searchString" id="searchStringInput" autocomplete="off" class="form-control rounded-pill-start border-end-0 ps-4" 
                                   placeholder="Bạn muốn ăn gì hôm nay?" style="height: 45px;">
                            <button type="submit" class="btn btn-white border border-start-0 text-muted" style="height: 45px;">
                                <i class="bi bi-search"></i>
                            </button>
                            <a href="/filter" class="btn btn-danger rounded-pill-end px-3 d-flex align-items-center" style="height: 45px;">
                                <i class="bi bi-sliders me-1"></i> Bộ Lọc
                            </a>
                        </div>
                        
                        <!-- Search Suggestions Dropdown -->
                        <div id="searchSuggestionsBox" class="position-absolute bg-white shadow border border-light rounded-4 w-100 d-none" style="top: 55px; z-index: 1050; max-height: 400px; overflow-y: auto;">
                        </div>
                    </form>
                </div>

                <ul class="navbar-nav ms-auto align-items-center">
                    @{
                        var vaiTro = Context.Session.GetString("VaiTro");
                        var tenDangNhap = Context.Session.GetString("TenDangNhap");

                        if (vaiTro == "KhachHang" || string.IsNullOrEmpty(vaiTro))
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link position-relative text-dark" asp-controller="Cart" asp-action="Index" title="Giỏ Hàng">
                                    <i class="bi bi-cart3 fs-5 text-danger"></i>
                                    <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 0.65em;">
                                        0
                                    </span>
                                </a>
                            </li>
                        }

                        if (!string.IsNullOrEmpty(vaiTro))
                        {
                            if (vaiTro == "DoiTac")
                            {
                                <li class="nav-item me-3 d-flex align-items-center">
                                    <div class="dropdown">
                                        <a class="nav-link position-relative text-dark dropdown-toggle" href="#" id="partnerNotifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                                            <i class="bi bi-bell fs-5 text-warning"></i>
                                            <span id="partner-notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 0.65em;">
                                                0
                                            </span>
                                        </a>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-0" aria-labelledby="partnerNotifDropdown" style="width: 250px;">
                                            <li class="p-3 border-bottom bg-light">
                                                <h6 class="mb-0 fw-bold">Thông báo đơn hàng</h6>
                                            </li>
                                            <li>
                                                <a class="dropdown-item py-3 d-flex align-items-center" asp-controller="QuanLyGianHang" asp-action="QuanLyDonHang">
                                                    <div class="bg-warning text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 32px; height: 32px;">
                                                        <i class="bi bi-box-seam"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold small text-dark mb-1">Chờ xác nhận</div>
                                                        <div class="text-muted" style="font-size: 12px;">Có <span id="partner-pending-count" class="fw-bold text-danger">0</span> đơn hàng mới</div>
                                                    </div>
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </li>
                            }

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 32px; height: 32px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <span class="fw-bold text-dark">@tenDangNhap</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                    <li class="px-3 py-2 text-muted small bg-light">
                                        VAI TRÒ: <strong>@(vaiTro == "KhachHang" ? "Khách Hàng" : vaiTro == "DoiTac" ? "Đối Tác" : "Quản Trị")</strong>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    @if (vaiTro == "DoiTac")
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="QuanLyGianHang" asp-action="Index"><i class="bi bi-shop me-2"></i>Quản lý quán ăn</a></li>
                                    }
                                    else if (vaiTro == "Admin")
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard Quản Trị</a></li>
                                    }
                                    else if (vaiTro == "KhachHang")
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="KhachHang" asp-action="Index"><i class="bi bi-person-lines-fill me-2"></i>Thông tin cá nhân</a></li>
                                        <li><a class="dropdown-item py-2" asp-controller="KhachHang" asp-action="DonMua"><i class="bi bi-bag-check me-2"></i>Đơn mua</a></li>
                                    }
                                    <li><a class="dropdown-item text-danger py-2 mt-1" asp-controller="Account" asp-action="DangXuat"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary px-3 me-2" asp-controller="Account" asp-action="DangNhap">Đăng Nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white px-3" asp-controller="Account" asp-action="DangKy">Đăng Ký</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </nav>

    @{
        var vaiTroLayout = Context.Session.GetString("VaiTro");
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        if (vaiTroLayout == "Admin" && currentController == "Admin")
        {
            <!-- Show Sidebar for Admin -->
            @await Html.PartialAsync("_AdminSidebar")
        }
        else if (vaiTroLayout == "DoiTac" && currentController == "QuanLyGianHang")
        {
            <!-- Show Sidebar for Partner -->
            @await Html.PartialAsync("_PartnerSidebar")
        }
    }

    <div class="main-container">
        <div class="container-fluid">
            @{
                if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                if (TempData["Info"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        @TempData["Info"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
            }
            @RenderBody()
        </div>
    </div>

    <footer class="border-top bg-white mt-auto">
        <div class="container text-center py-4">
            <p class="text-muted mb-0">&copy; 2026 - Hệ Thống Quản Lý Dịch Vụ Ăn Uống</p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Thêm jQuery nếu chưa có (cần cho AJAX) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function updateCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function (res) {
                    var badge = $('#cart-badge');
                    if (res && res.count > 0) {
                        badge.text(res.count).show();
                    } else {
                        badge.hide();
                    }
                }
            });
        }

        function updatePartnerNotifCount() {
            if ($('#partner-notif-badge').length > 0) {
                $.ajax({
                    url: '/QuanLyGianHang/GetPendingOrdersCount',
                    type: 'GET',
                    success: function (res) {
                        if (res && res.success && res.count > 0) {
                            $('#partner-notif-badge').text(res.count).show();
                            $('#partner-pending-count').text(res.count);
                        } else {
                            $('#partner-notif-badge').hide();
                            $('#partner-pending-count').text('0');
                        }
                    }
                });
            }
        }

        $(document).ready(function () {
            // Initial load of cart numeric indicator
            updateCartCount();
            
            // Initial load of partner notification
            updatePartnerNotifCount();
            
            // Poll for partner notifications every 30 seconds
            if ($('#partner-notif-badge').length > 0) {
                setInterval(updatePartnerNotifCount, 30000);
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
    $(function() {
        // Search Suggestions Logic
        let searchTimer;
        $('#searchStringInput').on('input', function() {
            clearTimeout(searchTimer);
            const q = $(this).val().trim();
            const box = $('#searchSuggestionsBox');
            
            if (q.length < 2) {
                box.addClass('d-none');
                return;
            }

            searchTimer = setTimeout(() => {
                $.getJSON('/Home/SearchSuggestions?q=' + encodeURIComponent(q), function(data) {
                    if (data.monAn.length === 0 && data.gianHang.length === 0) {
                        box.html('<div class="p-3 text-center text-muted"><i class="bi bi-search d-block fs-3 mb-2"></i>Không tìm thấy kết quả</div>');
                        box.removeClass('d-none');
                        return;
                    }

                    let html = '<div class="list-group list-group-flush rounded-4">';
                    
                    if (data.gianHang.length > 0) {
                        html += '<div class="bg-light px-3 py-2 fw-bold text-muted small"><i class="bi bi-shop me-2"></i>Gian hàng</div>';
                        data.gianHang.forEach(g => {
                            const img = g.hinh ? '/images/gianhang/' + g.hinh : '/images/default_store.jpg';
                            html += `
                            <a href="/Home/StoreDetails/${g.id}" class="list-group-item list-group-item-action d-flex align-items-center px-3 py-2 border-0">
                                <img src="${img}" class="rounded-circle me-3 shadow-sm" style="width:40px; height:40px; object-fit:cover;" onerror="this.src='/images/default_store.jpg'">
                                <div>
                                    <div class="fw-bold text-dark mb-0">${g.ten}</div>
                                    <div class="small text-muted text-truncate" style="max-width: 250px;"><i class="bi bi-geo-alt-fill text-danger me-1"></i>${g.diaChi || 'Đang cập nhật'}</div>
                                </div>
                            </a>`;
                        });
                    }

                    if (data.monAn.length > 0) {
                        html += '<div class="bg-light px-3 py-2 fw-bold text-muted small"><i class="bi bi-egg-fried me-2"></i>Món ăn</div>';
                        data.monAn.forEach(m => {
                            const img = m.hinh ? '/images/monan/' + m.hinh : '/images/default_food.jpg';
                            const price = new Intl.NumberFormat('vi-VN').format(m.gia) + 'đ';
                            html += `
                            <a href="/Home/MonAnDetails/${m.id}" class="list-group-item list-group-item-action d-flex align-items-center px-3 py-2 border-0">
                                <img src="${img}" class="rounded me-3 shadow-sm" style="width:40px; height:40px; object-fit:cover;" onerror="this.src='/images/default_food.jpg'">
                                <div>
                                    <div class="fw-bold text-dark mb-0">${m.ten}</div>
                                    <div class="small text-danger fw-bold">${price}</div>
                                </div>
                            </a>`;
                        });
                    }
                    
                    html += '</div>';
                    box.html(html);
                    box.removeClass('d-none');
                });
            }, 350);
        });

        // Hide box when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest('#mainSearchForm').length) {
                $('#searchSuggestionsBox').addClass('d-none');
            }
        });
        
        // Show box again when focusing input if it has text
        $('#searchStringInput').on('focus', function() {
            if ($(this).val().trim().length >= 2 && $('#searchSuggestionsBox').html().trim() !== '') {
                $('#searchSuggestionsBox').removeClass('d-none');
            }
        });
    });
    </script>
</body>
</html>
