@{
    ViewData["Title"] = "Thanh toán MoMo";
    Layout = null; // No layout to simulate an external payment gateway
    var orderIds = ViewBag.OrderIds as string;
    var totalAmount = ViewBag.TotalAmount as decimal? ?? 0;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cổng Thanh Toán MoMo (Mockup)</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background-color: #f3f3f3;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .momo-header {
            background-color: #a50064;
            color: white;
            padding: 15px 0;
            text-align: center;
        }
        .momo-container {
            max-width: 600px;
            margin: 40px auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .qr-placeholder {
            width: 250px;
            height: 250px;
            background-color: #fff;
            border: 2px dashed #a50064;
            margin: 20px auto;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="momo-header">
        <h4 class="mb-0 fw-bold"><i class="bi bi-wallet2 me-2"></i>Cổng Thanh Toán Điện Tử MoMo</h4>
    </div>

    <div class="momo-container">
        <div class="p-4 border-bottom">
            <h5 class="fw-bold mb-3 text-center text-dark">Quét Mã QR Để Thanh Toán</h5>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Nhà cung cấp:</span>
                <span class="fw-bold">HUIT Food</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Mã đơn hàng:</span>
                <span class="fw-bold">@orderIds</span>
            </div>
            <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                <span class="text-muted">Số tiền:</span>
                <span class="fw-bold text-danger fs-4">@String.Format("{0:0,0}đ", totalAmount)</span>
            </div>

            <div class="text-center">
                <div class="qr-placeholder">
                    <div class="text-center">
                        <i class="bi bi-qr-code-scan text-muted" style="font-size: 80px;"></i>
                        <p class="mt-2 text-muted fw-bold">Mã QR giả lập</p>
                    </div>
                </div>
                <p class="text-muted small">Sử dụng ứng dụng MoMo hoặc ứng dụng camera hỗ trợ QR code để quét mã.</p>
            </div>
        </div>
        
        <div class="p-4 bg-light text-center">
            <h6 class="fw-bold text-dark mb-3">Mô phỏng thao tác của người dùng</h6>
            <button id="btnMockSuccess" class="btn text-white w-100 py-3 fw-bold rounded-pill mb-3" style="background-color: #a50064;">
                <i class="bi bi-check-circle-fill me-2"></i> Giả lập quét mã và thanh toán THÀNH CÔNG
            </button>
            <button id="btnMockCancel" class="btn btn-outline-secondary w-100 py-2 fw-bold rounded-pill">
                <i class="bi bi-x-circle me-2"></i> Hủy giao dịch
            </button>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            var orderIds = '@orderIds';

            $('#btnMockSuccess').click(function() {
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');

                $.ajax({
                    url: '/Cart/ConfirmMoMoPayment',
                    type: 'POST',
                    data: { orderIds: orderIds },
                    success: function(res) {
                        if (res.success) {
                            Swal.fire({
                                title: 'Thanh toán thành công!',
                                text: 'Giao dịch MoMo đã hoàn tất.',
                                icon: 'success',
                                confirmButtonColor: '#a50064',
                                allowOutsideClick: false
                            }).then(() => {
                                window.location.href = '/khachhang/don-mua';
                            });
                        }
                    }
                });
            });

            $('#btnMockCancel').click(function() {
                Swal.fire({
                    title: 'Giao dịch bị hủy',
                    text: 'Bạn đã hủy thanh toán đơn hàng.',
                    icon: 'warning',
                    confirmButtonColor: '#a50064',
                }).then(() => {
                    // Back to order history where they can see the order as "Chờ thanh toán MoMo" or similar
                    window.location.href = '/khachhang/don-mua';
                });
            });
        });
    </script>
</body>
</html>


