@using QuanLyBanHangDoAnThucUong.Models.Entities
@model DonHang

@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng #" + Model.MaDonHang;
}

<div style="margin-left: 250px; margin-top: 20px; padding-bottom: 50px;">
    <div class="container-fluid">
        <div class="mb-4">
            <a asp-action="QuanLyDonHang" class="btn btn-outline-secondary rounded-pill shadow-sm">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>

        <div class="row">
            <!-- Order Info Column -->
            <div class="col-lg-8">
                <div class="card shadow border-0 rounded-4 mb-4">
                    <div class="card-header bg-dark text-white py-3 rounded-top-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 fw-bold"><i class="bi bi-receipt me-2"></i>Đơn hàng #@Model.MaDonHang</h4>
                            <span class="badge bg-light text-dark py-2 px-3 rounded-pill fw-bold">@Model.TrangThaiDonHang</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3">Sản phẩm</th>
                                        <th class="text-center py-3">Số lượng</th>
                                        <th class="text-end py-3">Đơn giá</th>
                                        <th class="text-end pe-4 py-3">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ChiTietDonHangs != null)
                                    {
                                        foreach (var detail in Model.ChiTietDonHangs)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="d-flex align-items-center py-2">
                                                        <div class="rounded-3 bg-light p-1 me-3" style="width: 50px; height: 50px; overflow: hidden;">
                                                            @{
                                                                var imgSrc = string.IsNullOrEmpty(detail.BienTheMonAn?.HinhAnhMonAn) ? "/images/default_food.jpg" : $"/images/monan/{detail.BienTheMonAn.HinhAnhMonAn}";
                                                            }
                                                            <img src="@imgSrc" class="img-fluid object-fit-cover w-100 h-100" />
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0 fw-bold">@detail.BienTheMonAn?.MonAn?.TenMon</h6>
                                                            <small class="text-muted">Mã biến thể: #@detail.MaBienThe</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center fw-bold">@detail.SoLuongMua</td>
                                                <td class="text-end">@detail.GiaBan.ToString("#,##0") đ</td>
                                                <td class="text-end pe-4 fw-bold">@((detail.GiaBan * detail.SoLuongMua).ToString("#,##0")) đ</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-4">
                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Tổng cộng món:</span>
                                    <span class="fw-bold">@Model.ThanhTienKhachTra.ToString("#,##0") đ</span>
                                </div>
                                @* <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Phí ship:</span>
                                    <span class="fw-bold">20,000 đ</span>
                                </div> *@
                                <hr>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <h5 class="mb-0 fw-bold">Tổng thanh toán:</h5>
                                    <h4 class="mb-0 fw-bold text-danger">@Model.ThanhTienKhachTra.ToString("#,##0") đ</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Customer & Store Info Column -->
            <div class="col-lg-4">
                <!-- Customer info card -->
                <div class="card shadow border-0 rounded-4 mb-4">
                    <div class="card-header bg-primary text-white py-3 rounded-top-4">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-person-fill me-2"></i>Khách hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                <i class="bi bi-person"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@(Model.KhachHang?.TenKH ?? "Khách vãng lai")</h6>
                                <p class="mb-0 text-muted small">@Model.KhachHang?.EmailKH</p>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="bi bi-telephone text-primary me-2"></i> @(Model.KhachHang?.SoDTKH ?? "N/A")</li>
                            <li class="mb-2"><i class="bi bi-geo-alt text-danger me-2"></i> @(Model.KhachHang?.DiaChiCuThe ?? "N/A")</li>
                            <li><i class="bi bi-calendar3 text-info me-2"></i> Ngày đăng ký: @(Model.KhachHang?.NgayDangKy.ToString("dd/MM/yyyy") ?? "N/A")</li>
                        </ul>
                    </div>
                </div>

                <!-- Store info card -->
                <div class="card shadow border-0 rounded-4 mb-4">
                    <div class="card-header bg-success text-white py-3 rounded-top-4">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-shop me-2"></i>Gian hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                <i class="bi bi-house-door"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@Model.GianHang?.TenGianHang</h6>
                                <p class="mb-0 text-muted small">Mã: #@Model.MaGianHang</p>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="bi bi-geo-alt text-success me-2"></i> @Model.GianHang?.DiaChiCuThe</li>
                            <li><i class="bi bi-clock text-warning me-2"></i> Giờ mở cửa: @Model.GianHang?.GioMo - @Model.GianHang?.GioDong</li>
                        </ul>
                    </div>
                </div>、
                
                <!-- Time Audit info card -->
                <div class="card shadow border-0 rounded-4">
                    <div class="card-header bg-info text-white py-3 rounded-top-4">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Lịch sử</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex mb-3">
                            <div class="vr me-3"></div>
                            <div>
                                <p class="mb-0 fw-bold">Ngày tạo đơn</p>
                                <p class="text-muted small">@Model.NgayTaoDon.ToString("dd/MM/yyyy HH:mm:ss")</p>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="vr me-3 text-success"></div>
                            <div>
                                <p class="mb-0 fw-bold">Cập nhật lần cuối</p>
                                <p class="text-muted small">@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        overflow-x: hidden;
    }
    .vr {
        width: 3px;
        background-color: #dee2e6;
        opacity: 1;
    }
</style>


