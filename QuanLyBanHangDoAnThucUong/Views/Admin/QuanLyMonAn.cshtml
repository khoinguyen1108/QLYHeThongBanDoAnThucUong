@using QuanLyBanHangDoAnThucUong.Models.Entities
@model List<MonAn>

@{
    ViewData["Title"] = "Quản Lý Món Ăn";
}

<div style="margin-left: 250px; margin-top: 20px;">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0 fw-bold"><i class="bi bi-egg-fried text-primary me-2"></i>🍜 Quản Lý Món Ăn</h2>
            <div class="badge bg-primary fs-5 px-4 py-2 shadow-sm rounded-pill">
                Tổng: @ViewBag.TotalCount món ăn
            </div>
        </div>

        <!-- Search & Filter Controls -->
        <div class="card shadow border-0 rounded-4 mb-4 bg-white">
            <div class="card-body p-3">
                <div class="row g-3 align-items-center">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" id="monAnSearchInput" class="form-control bg-light border-start-0 border-light" placeholder="Tìm kiếm tên món, gian hàng, loại món...">
                        </div>
                    </div>
                    <div class="col-md-6 text-end">
                        <button id="btnResetFilters" class="btn btn-outline-secondary rounded-pill px-3 fw-bold"><i class="bi bi-arrow-counterclockwise me-1"></i>Đặt lại</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0" id="monAnTable">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 sortable" style="cursor: pointer;"># <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 sortable" style="cursor: pointer;">Tên Món <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 sortable" style="cursor: pointer;">Gian Hàng <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 sortable" style="cursor: pointer;">Loại Món <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 sortable" style="cursor: pointer;">Số Biến Thể <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 sortable" style="cursor: pointer;">Đối Tác <i class="bi bi-arrow-down-up small ms-1 opacity-50"></i></th>
                            <th class="py-3 text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">Không có dữ liệu</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var mon in Model)
                            {
                                <tr>
                                    <td>@mon.MaMonAn</td>
                                    <td><strong>@mon.TenMon</strong></td>
                                    <td>@mon.GianHang?.TenGianHang</td>
                                    <td>
                                        <span class="badge bg-info">@mon.TheLoaiMonAn?.TenLoai</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">@mon.BienTheMonAns.Count</span>
                                    </td>
                                    <td>@mon.GianHang?.DoiTac?.TenQuanDoiTac</td>
                                    <td>
                                        <button class="btn btn-sm btn-info"
                                                onclick="xemChiTiet(@mon.MaMonAn, '@mon.TenMon', '@mon.TheLoaiMonAn?.TenLoai', '@mon.GianHang?.TenGianHang')"
                                                data-bs-toggle="modal" data-bs-target="#chiTietMonModal">
                                            👁️ Chi Tiết
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="QuanLyMonAn" asp-route-page="1">Đầu Tiên</a>
                                </li>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="QuanLyMonAn" asp-route-page="@i">@i</a>
                                </li>
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="QuanLyMonAn" asp-route-page="@ViewBag.TotalPages">Cuối Cùng</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }

                <!-- Removed Bottom Total -->
            </div>
        </div>
    </div>
</div>

<!-- Modal Chi Tiết Món Ăn -->
<div class="modal fade" id="chiTietMonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">📋 Chi Tiết Món Ăn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Tên Món:</strong> <span id="modalTenMon"></span></p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Loại Món:</strong> <span id="modalLoaiMon"></span></p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Gian Hàng:</strong> <span id="modalGianHang"></span></p>
                    </div>
                </div>
                <hr />
                <h6 class="fw-bold mb-3">Các Biến Thể:</h6>
                <div id="modalBienThes"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        overflow-x: hidden;
    }
    .sortable:hover {
        background-color: rgba(255,255,255,0.15) !important;
    }
    .sortable.asc i::before {
        content: "\f124";
        font-family: "bootstrap-icons";
        opacity: 1 !important;
    }
    .sortable.desc i::before {
        content: "\f121";
        font-family: "bootstrap-icons";
        opacity: 1 !important;
    }
</style>

<script>
    function xemChiTiet(maMonAn, tenMon, loaiMon, gianHang) {
        document.getElementById('modalTenMon').textContent = tenMon;
        document.getElementById('modalLoaiMon').textContent = loaiMon;
        document.getElementById('modalGianHang').textContent = gianHang;

        // Fetch biến thể
        fetch(`/Admin/GetBienTheMonAn?maMonAn=${maMonAn}`)
            .then(response => response.json())
            .then(data => {
                let html = '';
                if (data.length === 0) {
                    html = '<p class="text-muted">Không có biến thể nào</p>';
                } else {
                    data.forEach(bt => {
                        html += `
                            <div class="card mb-2">
                                <div class="card-body">
                                    <p class="mb-2"><strong>Mô Tả:</strong> ${bt.moTaMonAn}</p>
                                    <p class="mb-2"><strong>Giá:</strong> ${bt.giaBan.toLocaleString('vi-VN')} VNĐ</p>
                                    <p class="mb-2"><strong>Số Lượng:</strong> ${bt.soLuongMon}</p>
                                    <p class="mb-0"><strong>Trạng Thái:</strong> <span class="badge bg-${bt.trangThaiMonAn === 'Còn bán' ? 'success' : 'danger'}">${bt.trangThaiMonAn}</span></p>
                                </div>
                            </div>
                        `;
                    });
                }
                document.getElementById('modalBienThes').innerHTML = html;
            });
    }

    $(document).ready(function() {
        // Search filter
        $('#monAnSearchInput').on('keyup', function() {
            var value = $(this).val().toLowerCase().trim();
            $('#monAnTable tbody tr').each(function() {
                var row = $(this);
                if (row.find('td').length > 1) {
                    var text = row.text().toLowerCase();
                    if (text.indexOf(value) > -1) {
                        row.show();
                    } else {
                        row.hide();
                    }
                }
            });
        });

        // Reset filter
        $('#btnResetFilters').click(function() {
            $('#monAnSearchInput').val('');
            $('#monAnTable tbody tr').show();
        });

        // Client-side sorting
        $('.sortable').click(function() {
            var th = $(this);
            var table = th.closest('table');
            var tbody = table.find('tbody');
            var rows = tbody.find('tr').toArray();
            var index = th.index();
            var ascending = !th.hasClass('asc');

            table.find('th').removeClass('asc desc');
            th.toggleClass('asc', ascending).toggleClass('desc', !ascending);

            rows.sort(function(a, b) {
                var cellA = $(a).children('td').eq(index).text().trim();
                var cellB = $(b).children('td').eq(index).text().trim();

                // Numbers sorting (like # or Count of variants)
                if (!isNaN(cellA) && !isNaN(cellB)) {
                    return ascending ? parseFloat(cellA) - parseFloat(cellB) : parseFloat(cellB) - parseFloat(cellA);
                }

                return ascending ? cellA.localeCompare(cellB) : cellB.localeCompare(cellA);
            });

            $.each(rows, function(index, row) {
                tbody.append(row);
            });
        });
    });
</script>
