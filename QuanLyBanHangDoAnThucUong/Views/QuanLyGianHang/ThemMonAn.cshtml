@using QuanLyBanHangDoAnThucUong.Models.ViewModels
@using QuanLyBanHangDoAnThucUong.Models.Entities
@model ThemMonAnViewModel

@{
    ViewData["Title"] = "Thêm Món Ăn Mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <h3 class="card-title text-center mb-4 text-primary fw-bold">
                        ➕ Thêm Món Ăn Mới
                    </h3>

                    <form method="post" asp-action="ThemMonAn" enctype="multipart/form-data">
                        <h5 class="mb-3 border-bottom pb-2">Thông Tin Món Ăn</h5>

                        <div class="mb-3">
                            <label asp-for="TenMon" class="form-label fw-bold"></label>
                            <input class="form-control" asp-for="TenMon" placeholder="Nhập tên món ăn" required>
                            <span asp-validation-for="TenMon" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 text-center">
                             <div class="mb-2">
                                 <img id="previewImg" src="/images/default_food.jpg" class="img-thumbnail" style="height: 150px; width: 150px; object-fit: cover;">
                             </div>
                             <label class="form-label fw-bold">Hình Ảnh Món Ăn</label>
                             <input type="file" name="FileHinh" class="form-control" id="fileInput" accept="image/*" onchange="previewFile()">
                             <small class="text-muted">Chọn ảnh từ máy tính của bạn</small>
                        </div>

                        <script>
                            function previewFile() {
                                const preview = document.getElementById('previewImg');
                                const file = document.getElementById('fileInput').files[0];
                                const reader = new FileReader();

                                reader.onloadend = function () {
                                    preview.src = reader.result;
                                }

                                if (file) {
                                    reader.readAsDataURL(file);
                                } else {
                                    preview.src = "/images/default_food.jpg";
                                }
                            }
                        </script>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaLoaiMon" class="form-label fw-bold"></label>
                                <select class="form-control" asp-for="MaLoaiMon" required>
                                    <option value="">-- Chọn Loại Món --</option>
                                    @foreach (var item in (List<TheLoaiMonAn>)ViewBag.LoaiMonAn)
                                    {
                                        <option value="@item.MaLoaiMon">@item.TenLoai</option>
                                    }
                                </select>
                                <span asp-validation-for="MaLoaiMon" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MoTaMonAn" class="form-label fw-bold"></label>
                                <input class="form-control" asp-for="MoTaMonAn" placeholder="Mô tả ngắn" required>
                                <span asp-validation-for="MoTaMonAn" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="GiaBan" class="form-label fw-bold"></label>
                                <input type="number" class="form-control" asp-for="GiaBan" placeholder="10000" step="1000" required>
                                <span asp-validation-for="GiaBan" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuongMon" class="form-label fw-bold"></label>
                                <input type="number" class="form-control" asp-for="SoLuongMon" placeholder="0" required>
                                <span asp-validation-for="SoLuongMon" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="mb-3 border-bottom pb-2 mt-4">Thông Tin Bổ Sung</h5>

                        <div class="mb-3">
                            <label asp-for="GhiChu" class="form-label fw-bold"></label>
                            <input type="text" class="form-control" asp-for="GhiChu"
                                   placeholder="VD: Không hành, ít đá, cay nhiều...">
                            <small class="text-muted">Ghi chú thêm về món ăn</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MonAnMuaThem" class="form-label fw-bold"></label>
                            <input type="text" class="form-control" asp-for="MonAnMuaThem"
                                   placeholder="VD: Nước ngọt, Thêm gia vị...">
                            <small class="text-muted">Các tùy chọn kèm thêm</small>
                        </div>

                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                        {
                            <div class="alert alert-danger">
                                <ul class="mb-0">
                                    @foreach (var modelState in ViewData.ModelState.Values)
                                    {
                                        @foreach (var error in modelState.Errors)
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg fw-bold">
                                ✅ Thêm Món Ăn
                            </button>
                            <a asp-action="QuanLyMonAn" class="btn btn-secondary">
                                ❌ Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
