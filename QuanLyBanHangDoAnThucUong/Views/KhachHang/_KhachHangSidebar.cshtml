@{
    var currentAction = ViewContext.RouteData.Values["Action"].ToString();
}

<div class="col-md-3 mb-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 text-center">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3 shadow-sm" style="width: 100px; height: 100px; font-size: 45px; border: 3px solid #f05023;">
                <i class="bi bi-person-fill"></i>
            </div>
            <h5 class="fw-bold mb-1">Tài khoản của tôi</h5>
            <p class="text-muted small mb-0">Quản lý cá nhân</p>
        </div>
        <div class="list-group list-group-flush rounded-bottom-4 border-top">
            <a href="/khachhang" class="list-group-item list-group-item-action py-3 @(currentAction == "Index" ? "active fw-bold text-white" : "")" style="@(currentAction == "Index" ? "background-color: #f05023; border-color: #f05023;" : "")">
                <i class="bi bi-house-door me-2"></i> Tổng quan
            </a>
            <a href="/khachhang/chinh-sua-ho-so" class="list-group-item list-group-item-action py-3 @(currentAction == "ThongTinKhachHang" ? "active fw-bold text-white" : "")" style="@(currentAction == "ThongTinKhachHang" ? "background-color: #f05023; border-color: #f05023;" : "")">
                <i class="bi bi-person-circle me-2"></i> Chỉnh sửa hồ sơ
            </a>
            <a href="/khachhang/don-mua" class="list-group-item list-group-item-action py-3 @(currentAction == "DonMua" ? "active fw-bold text-white" : "")" style="@(currentAction == "DonMua" ? "background-color: #f05023; border-color: #f05023;" : "")">
                <i class="bi bi-bag-check me-2"></i> Đơn mua
            </a>
            <a href="/Account/DangXuat" class="list-group-item list-group-item-action text-danger py-3">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </a>
        </div>
    </div>
</div>

