@model QuanLyBanHangDoAnThucUong.Models.Entities.MonAn
@using QuanLyBanHangDoAnThucUong.Helpers

@{
    ViewData["Title"] = Model.TenMon;
    var bienTheDauTien = Model.BienTheMonAns?.FirstOrDefault();
    var hinhAnh = bienTheDauTien?.HinhAnhMonAn ?? "default-food.png";
    var soSao = Model.SoSaoTrungBinh ?? 0;
    var soLuot = Model.SoLuotDanhGia ?? 0;
    var foodImgSrc = string.IsNullOrEmpty(bienTheDauTien?.HinhAnhMonAn) ? "/images/default_food.jpg" : $"/images/monan/{bienTheDauTien.HinhAnhMonAn}";
    
    var citySlug = SlugHelper.GenerateSlugOptimal(Model.GianHang?.ThanhPho ?? "tp");
    var storeSlug = SlugHelper.GenerateSlugOptimal(Model.GianHang?.TenGianHang ?? "store");
    var storeUrl = $"/home/storedetails/{Model.MaGianHang}?cityslug={citySlug}&storeslug={storeSlug}";
}

<div class="container mt-4 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="@storeUrl" class="text-decoration-none">@Model.GianHang?.TenGianHang</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenMon</li>
        </ol>
    </nav>

    <!-- Top Row: Product Details (Full Width) -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border border-light shadow-sm rounded-0">
                <div class="row g-0 h-100">
                    <div class="col-md-6 border-end d-flex align-items-center justify-content-center bg-light">
                        <img src="@foodImgSrc" class="img-fluid" alt="@Model.TenMon" onerror="this.src='/images/default_food.jpg'" style="max-height: 400px; object-fit: contain;">
                    </div>
                    <div class="col-md-6 px-4 py-3 d-flex flex-column">
                        <h4 class="fw-bold mb-2">@Model.TenMon</h4>
                        
                        <div class="d-flex align-items-center mb-4 text-warning" style="font-size: 0.9rem;">
                            @if (soLuot > 0)
                            {
                                <span class="text-dark fw-bold me-2" style="font-size: 1.1rem;">@soSao.ToString("0.#")</span>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round((decimal)soSao)) { <i class="bi bi-star-fill"></i> }
                                    else { <i class="bi bi-star"></i> }
                                }
                                <span class="text-muted ms-2">| @soLuot đánh giá</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Chưa có đánh giá</span>
                            }
                            <span class="badge bg-secondary ms-auto">@Model.TheLoaiMonAn?.TenLoai</span>
                        </div>
                        
                        @if (Model.BienTheMonAns != null && Model.BienTheMonAns.Any())
                        {
                            var primaryVariant = Model.BienTheMonAns.First();
                            <div class="mb-4">
                                <span class="fs-2 fw-bold text-danger" id="displayPrice">@string.Format("{0:N0}", primaryVariant.GiaBan)đ</span>
                            </div>
                            
                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="text-dark fw-bold">Số lượng:</div>
                                    <div class="input-group border rounded-pill overflow-hidden" style="width: 140px; background-color: #f8f9fa;">
                                        <button class="btn border-0 px-3 fw-bold text-muted opacity-50" type="button" id="btnDecreaseQty" disabled><i class="bi bi-dash-lg"></i></button>
                                        <input type="text" class="form-control text-center fw-bold border-0 bg-transparent px-0" id="inputQuantity" value="1" readonly>
                                        <button class="btn border-0 px-3 text-dark fw-bold" type="button" id="btnIncreaseQty"><i class="bi bi-plus-lg"></i></button>
                                    </div>
                                </div>
                                
                                <div class="mt-2">
                                    <button class="btn btn-danger rounded-pill shadow-sm px-4 py-2 btn-add-cart-main fw-bold" id="mainAddToCartBtn" data-variant-id="@primaryVariant.MaBienThe">
                                        <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Details and Similar Foods -->
    <div class="row">
        <!-- Left Column: Ingredients, Store, Reviews -->
        <div class="col-lg-8 col-md-12 mb-4">
            <!-- Thành phần & Mô tả -->
            <div class="card border border-light shadow-sm rounded-0 p-4 mb-4 bg-white">
                <h6 class="fw-bold text-dark mb-2">THÀNH PHẦN:</h6>
                <p class="text-muted small mb-4">@(string.IsNullOrEmpty(Model.ThanhPhan) ? "Chưa có thông tin thành phần chi tiết." : Model.ThanhPhan)</p>
                
                <h6 class="fw-bold text-dark mb-2">MÔ TẢ:</h6>
                <p class="text-muted small mb-0">Món ăn được chuẩn bị với những nguyên liệu tươi ngon nhất, mang đến hương vị đậm đà và trải nghiệm tuyệt vời cho thực khách.</p>
            </div>

            <!-- Store Info Card -->
            <div class="card border border-light shadow-sm mt-3 mb-4 rounded-0 p-2">
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
                        <div class="d-flex align-items-center mb-3 mb-md-0">
                            <img src="@(string.IsNullOrEmpty(Model.GianHang?.HinhAnh) ? "/images/default_store.jpg" : $"/images/gianhang/{Model.GianHang.HinhAnh}")" 
                                 class="rounded-circle shadow-sm me-4 border" style="width: 80px; height: 80px; object-fit: cover;" alt="@Model.GianHang?.TenGianHang" />
                            <div>
                                <h5 class="fw-bold mb-1">@Model.GianHang?.TenGianHang</h5>
                                <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@Model.GianHang?.DiaChiCuThe, @Model.GianHang?.ThanhPho</p>
                                <div class="d-flex gap-4">
                                    
                                    @{
                                        var totalStoreReviews = Model.GianHang?.MonAns?.Sum(m => m.SoLuotDanhGia ?? 0) ?? 0;
                                        string displayStoreReviews = totalStoreReviews >= 1000 ? (totalStoreReviews / 1000.0).ToString("0.#") + "K" : totalStoreReviews.ToString();
                                    }
                                    <div class="text-center">
                                        <div class="fw-bold" style="font-size: 0.9rem;">@displayStoreReviews</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Đánh giá</div>
                                    </div>
                                    <div class="text-center">
                                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Mở cửa</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">Trạng thái</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <a href="@storeUrl" class="btn btn-outline-danger rounded-pill px-4 py-2" style="font-weight: 500;">
                                <i class="bi bi-shop me-2"></i>Xem gian hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== REVIEWS ===== -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mt-4" id="reviewSection" style="background-color: #fafbfe;">
                <div class="card-body p-0">
                    <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-chat-left-dots-fill text-primary me-2"></i>Đánh giá sản phẩm</h5>

                    <div class="row align-items-center mb-4 bg-white p-4 rounded-4 shadow-sm mx-0">
                        <div class="col-md-4 text-center border-end-md">
                            <h1 class="display-3 fw-bold text-dark mb-0" id="avgStar">@soSao.ToString("0.#") <span class="fs-5 text-muted">trên 5</span></h1>
                            <div id="avgStarIcons" class="text-warning fs-5 mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round((decimal)soSao)) { <i class="bi bi-star-fill"></i> }
                                    else { <i class="bi bi-star"></i> }
                                }
                            </div>
                            
                            <div class="text-muted small fw-bold" id="reviewSummaryText">
                                @if (soLuot > 0)
                                {
                                    <span id="totalReviewCount">@soLuot</span> @:ĐÁNH GIÁ
                                }
                                else
                                {
                                    @:Chưa có đánh giá
                                }
                            </div>
                            
                        </div>
                        <div class="col-md-8 ps-md-5 mt-4 mt-md-0" id="starBars">
                            <!-- Progress bars filled by JS -->
                        </div>
                    </div>
                    
                    <!-- Sắp xếp & Lọc đánh giá -->
                    <div class="d-flex flex-wrap gap-3 mb-4 justify-content-start align-items-center">
                        <span class="fw-bold text-dark d-none d-md-block"><i class="bi bi-funnel-fill text-muted me-1"></i>Bộ lọc:</span>
                        <div class="d-flex align-items-center bg-white rounded-pill px-3 py-2 shadow-sm border border-light">
                            <select class="form-select border-0 bg-transparent shadow-none fw-bold text-dark p-0" id="reviewSort" style="width: auto; cursor: pointer; background-image: none;">
                                <option value="newest">Mới nhất</option>
                                <option value="oldest">Cũ nhất</option>
                                <option value="highest">Sao cao nhất</option>
                                <option value="lowest">Sao thấp nhất</option>
                            </select>
                        </div>
                        <div class="d-flex align-items-center bg-white rounded-pill px-3 py-2 shadow-sm border border-light">
                            <select class="form-select border-0 bg-transparent shadow-none fw-bold text-dark p-0" id="reviewFilter" style="width: auto; cursor: pointer; background-image: none;">
                                <option value="0">Tất cả sao</option>
                                <option value="5">5 sao</option>
                                <option value="4">4 sao</option>
                                <option value="3">3 sao</option>
                                <option value="2">2 sao</option>
                                <option value="1">1 sao</option>
                            </select>
                        </div>
                    </div>

                    <!-- Danh sách đánh giá -->
                    <div id="reviewList" class="mb-4">
                        <div class="text-center py-5 text-muted"><i class="bi bi-hourglass-split fs-2 d-block mb-2"></i> Đang tải đánh giá...</div>
                    </div>

                    <!-- Pagination đánh giá -->
                    <nav id="reviewPagination" class="mb-5"></nav>

                    <!-- Form viết đánh giá -->
                    @if (Context.Session.GetInt32("MaKH") != null)
                    {
                        <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light mt-2">
                            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Viết đánh giá của bạn</h5>
                            <div class="mb-4 d-flex align-items-center">
                                <label class="form-label fw-bold me-4 mb-0 text-muted">Trải nghiệm của bạn thế nào?</label>
                                <div id="starRating" class="d-flex gap-2" style="cursor: pointer;">
                                    <i class="bi bi-star fs-3 text-muted" data-value="1"></i>
                                    <i class="bi bi-star fs-3 text-muted" data-value="2"></i>
                                    <i class="bi bi-star fs-3 text-muted" data-value="3"></i>
                                    <i class="bi bi-star fs-3 text-muted" data-value="4"></i>
                                    <i class="bi bi-star fs-3 text-muted" data-value="5"></i>
                                </div>
                                <input type="hidden" id="selectedStar" value="0">
                            </div>
                            <div class="mb-4">
                                <textarea class="form-control bg-light border-0 rounded-4 p-3" id="reviewContent" rows="4" placeholder="Hãy chia sẻ cảm nhận chi tiết của bạn về món ăn này nhé..." maxlength="500" style="resize: none;"></textarea>
                            </div>
                            <div class="text-end">
                                <button class="btn btn-primary px-5 py-2 rounded-pill fw-bold shadow-sm" id="btnSubmitReview">Gửi Đánh Giá</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Similar Foods -->
        <div class="col-lg-4 col-md-12 mb-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-magic text-danger me-2"></i>Món tương tự</h6>
            @if (ViewBag.SimilarItems != null)
            {
                var similarList = ViewBag.SimilarItems as List<QuanLyBanHangDoAnThucUong.Models.Entities.MonAn>;
                if (similarList != null && similarList.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach(var item in similarList.Take(3))
                        {
                            var firstBt = item.BienTheMonAns?.FirstOrDefault();
                            var itemSlug = SlugHelper.GenerateSlugOptimal(item.TenMon ?? "mon-an");
                            var simImgSrc = string.IsNullOrEmpty(firstBt?.HinhAnhMonAn) ? "/images/default_food.jpg" : $"/images/monan/{firstBt.HinhAnhMonAn}";
                            
                            <a href="/mon-an/@(itemSlug)-@(item.MaMonAn)" class="text-decoration-none text-dark d-block">
                                <div class="card border border-light shadow-sm flex-row align-items-center p-2 rounded-0">
                                    <img src="@simImgSrc" class="rounded" style="width: 70px; height: 70px; object-fit: cover;" alt="@item.TenMon" onerror="this.src='/images/default_food.jpg'">
                                    <div class="ms-3">
                                        <h6 class="mb-1 fw-bold text-truncate" style="max-width: 180px; font-size: 0.95rem;" title="@item.TenMon">@item.TenMon</h6>
                                        @if (item.SoLuotDanhGia > 0)
                                        {
                                            <div class="text-dark small mb-1 fw-bold">
                                                @(item.SoSaoTrungBinh?.ToString("0.#") ?? "0") <i class="bi bi-star-fill text-warning"></i>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small mb-1 fst-italic" style="font-size: 0.85rem;">Chưa có đánh giá</div>
                                        }
                                        <div class="text-danger fw-bold" style="font-size: 0.9rem;">@(firstBt != null ? string.Format("{0:N0}đ", firstBt.GiaBan) : "Hết hàng")</div>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
    $(function () {
        const maMonAn = @Model.MaMonAn;
        let currentPage = 1;

        // ===== QUANTITY =====
        let currentQty = 1;
        
        function updateQtyUI() {
            $('#inputQuantity').val(currentQty);
            if (currentQty <= 1) {
                $('#btnDecreaseQty').prop('disabled', true).removeClass('text-dark').addClass('text-muted opacity-50');
            } else {
                $('#btnDecreaseQty').prop('disabled', false).removeClass('text-muted opacity-50').addClass('text-dark');
            }
        }
        
        $('#btnIncreaseQty').on('click', function() {
            currentQty++;
            updateQtyUI();
        });
        $('#btnDecreaseQty').on('click', function() {
            if (currentQty > 1) {
                currentQty--;
                updateQtyUI();
            }
        });

        // ===== ADD TO CART =====
        $('#mainAddToCartBtn').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const variantId = $(this).data('variant-id');
            const qty = parseInt($('#inputQuantity').val()) || 1;
            addToCart(variantId, qty, false);
        });

        function addToCart(variantId, quantity, forceClear) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { maBienThe: variantId, soLuong: quantity, forceClear: forceClear },
                success: function(response) {
                    if (response.requireLogin) {
                        window.location.href = '/Account/DangNhap';
                        return;
                    }
                    if (response.requireConfirmation) {
                        Swal.fire({
                            title: 'Thông báo giỏ hàng',
                            text: response.message,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#f05023',
                            confirmButtonText: 'Đồng ý xoá và Thêm mới',
                            cancelButtonText: 'Hủy'
                        }).then((r) => { if (r.isConfirmed) addToCart(variantId, quantity, true); });
                        return;
                    }
                    if (response.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: response.message, showConfirmButton: false, timer: 1500 });
                        if (typeof updateCartCount === "function") updateCartCount();
                    } else {
                        Swal.fire('Lỗi', response.message, 'error');
                    }
                },
                error: function() { Swal.fire('Lỗi', 'Có lỗi kết nối.', 'error'); }
            });
        }

        // ===== REVIEWS =====
        loadReviews(1);

        $('#reviewSort').on('change', function() {
            loadReviews(1);
        });
        
        $('#reviewFilter').on('change', function() {
            loadReviews(1);
        });

        function loadReviews(page) {
            currentPage = page;
            const sort = $('#reviewSort').val();
            const filter = $('#reviewFilter').val();

            $.getJSON(`/Home/GetDanhGia?maMonAn=${maMonAn}&page=${page}&sort=${sort}&filterStar=${filter}`, function(data) {
                renderReviews(data.reviews);
                renderPagination(data.currentPage, data.totalPages);
                renderStarBars(data.starSummary, data.totalUnfilteredCount || data.totalCount);
                
                // Update filtered count text
                if (data.totalCount > 0) {
                    $('#reviewSummaryText').html(`<span id="totalReviewCount">${data.totalCount}</span> ĐÁNH GIÁ`);
                } else {
                    $('#reviewSummaryText').html(`Chưa có đánh giá`);
                }
            }).fail(function() {
                $('#reviewList').html('<div class="text-center py-5 text-muted"><i class="bi bi-exclamation-triangle fs-2 d-block mb-2 text-danger"></i> Lỗi khi tải đánh giá</div>');
            });
        }

        function renderReviews(reviews) {
            if (!reviews || reviews.length === 0) {
                $('#reviewList').html('<div class="text-center py-5 text-muted bg-white rounded-4 border border-light shadow-sm"><i class="bi bi-chat-square-text fs-1 d-block mb-3 text-light"></i><h6 class="fw-bold">Chưa có đánh giá</h6></div>');
                return;
            }
            let html = '';
            reviews.forEach(r => {
                let stars = '';
                for (let i = 1; i <= 5; i++) stars += i <= r.soSao ? '<i class="bi bi-star-fill text-warning me-1"></i>' : '<i class="bi bi-star text-muted opacity-50 me-1"></i>';
                
                let replyHtml = '';
                if (r.phanHoiCuaDoiTac && r.phanHoiCuaDoiTac.trim() !== '') {
                    replyHtml = `
                    <div class="mt-3 p-3 bg-light rounded-4 border-start border-4 border-primary">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-primary rounded-pill"><i class="bi bi-shop me-1"></i>Phản hồi từ quán</span>
                            <small class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-clock me-1"></i>${r.ngayPhanHoi || ''}</small>
                        </div>
                        <p class="mb-0 text-dark small">${r.phanHoiCuaDoiTac}</p>
                    </div>`;
                }
                
                let deleteHtml = '';
                if (r.isOwner) {
                    deleteHtml = `<button class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1 btn-delete-review" data-id="${r.maDanhGia}" title="Xóa đánh giá"><i class="bi bi-trash"></i> Xóa</button>`;
                }
                
                html += `
                <div class="bg-white p-4 rounded-4 shadow-sm border border-light mb-3">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-gradient text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 48px; height: 48px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <i class="bi bi-person-fill text-white fs-4"></i>
                            </div>
                            <div>
                                <strong class="d-block text-dark fs-6 mb-1">${r.tenKH}</strong>
                                <div class="small" style="font-size: 0.8rem;">${stars}</div>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="small text-muted fw-bold mb-2"><i class="bi bi-calendar3 me-1"></i>${r.ngayDanhGia}</div>
                            ${deleteHtml}
                        </div>
                    </div>
                    <p class="mb-0 text-dark" style="line-height: 1.6;">${r.noiDung || '<em class="text-muted">Không có nội dung đánh giá</em>'}</p>
                    ${replyHtml}
                </div>`;
            });
            $('#reviewList').html(html);
        }
        
        $(document).on('click', '.btn-delete-review', function() {
            const id = $(this).data('id');
            Swal.fire({
                title: 'Xóa đánh giá?',
                text: 'Bạn không thể hoàn tác hành động này!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Home/XoaDanhGia', { id: id }, function(res) {
                        if (res.success) {
                            Swal.fire({toast:true, position:'top-end', icon:'success', title:'Đã xóa thành công', showConfirmButton:false, timer:1500});
                            loadReviews(currentPage);
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    });
                }
            });
        });

        function renderPagination(current, total) {
            if (total <= 1) { $('#reviewPagination').html(''); return; }
            let html = '<ul class="pagination justify-content-center gap-1">';
            for (let i = 1; i <= total; i++) {
                html += `<li class="page-item ${i===current?'active':''}"><a class="page-link rounded-circle border-0 shadow-sm mx-1 ${i===current?'bg-primary text-white':'text-dark'}" href="javascript:void(0)" onclick="window.loadReviewPage(${i})" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; font-weight: bold;">${i}</a></li>`;
            }
            html += '</ul>';
            $('#reviewPagination').html(html);
        }
        window.loadReviewPage = function(p) { loadReviews(p); document.getElementById('reviewSection').scrollIntoView({ behavior: 'smooth' }); };

        function renderStarBars(summary, total) {
            let html = '';
            for (let s = 5; s >= 1; s--) {
                const found = summary.find(x => x.star === s);
                const count = found ? found.count : 0;
                const pct = total > 0 ? Math.round(count * 100 / total) : 0;
                html += `<div class="d-flex align-items-center mb-2">
                    <span class="small me-3 fw-bold text-dark d-flex align-items-center justify-content-end" style="width:40px;">${s}<i class="bi bi-star-fill text-warning ms-1" style="font-size:12px;"></i></span>
                    <div class="progress flex-grow-1 bg-light border" style="height:12px; border-radius:6px;">
                        <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated" style="width:${pct}%"></div>
                    </div>
                    <span class="small ms-3 text-muted fw-bold" style="width:30px; text-align:left;">${count}</span>
                </div>`;
            }
            $('#starBars').html(html);
        }

        // ===== STAR RATING INPUT =====
        let selectedStar = 0;
        $('#starRating i').on('click', function() {
            selectedStar = parseInt($(this).data('value'));
            $('#selectedStar').val(selectedStar);
            $('#starRating i').each(function() {
                const v = parseInt($(this).data('value'));
                $(this).removeClass('bi-star bi-star-fill text-warning text-muted');
                if (v <= selectedStar) { $(this).addClass('bi-star-fill text-warning'); }
                else { $(this).addClass('bi-star text-muted'); }
            });
        });
        $('#starRating i').on('mouseenter', function() {
            const hoverVal = parseInt($(this).data('value'));
            $('#starRating i').each(function() {
                const v = parseInt($(this).data('value'));
                $(this).removeClass('bi-star bi-star-fill text-warning text-muted');
                if (v <= hoverVal) { $(this).addClass('bi-star-fill text-warning'); }
                else { $(this).addClass('bi-star text-muted'); }
            });
        });
        $('#starRating').on('mouseleave', function() {
            $('#starRating i').each(function() {
                const v = parseInt($(this).data('value'));
                $(this).removeClass('bi-star bi-star-fill text-warning text-muted');
                if (v <= selectedStar) { $(this).addClass('bi-star-fill text-warning'); }
                else { $(this).addClass('bi-star text-muted'); }
            });
        });

        // ===== SUBMIT REVIEW =====
        $('#btnSubmitReview').on('click', function() {
            const star = parseInt($('#selectedStar').val());
            const content = $('#reviewContent').val().trim();

            if (star === 0) { Swal.fire('Thông báo', 'Vui lòng chọn số sao.', 'warning'); return; }

            const btn = $(this);
            btn.prop('disabled', true);
            btn.html('<i class="spinner-border spinner-border-sm me-1"></i>Đang xử lý...');

            $.ajax({
                url: '/Home/ThemDanhGia',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ maMonAn: maMonAn, soSao: star, noiDung: content }),
                success: function(res) {
                    if (res.requireLogin) { window.location.href = '/Account/DangNhap'; return; }
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Cảm ơn bạn đã đánh giá!', showConfirmButton: false, timer: 1500 });
                        setTimeout(function() {
                            window.location.reload();
                        }, 1500);
                    } else { 
                        Swal.fire('Lỗi', res.message, 'error'); 
                    }
                },
                error: function() {
                    Swal.fire('Lỗi', 'Đã có lỗi xảy ra. Vui lòng thử lại sau.', 'error');
                },
                complete: function() {
                    if (!btn.is(':disabled')) return; 
                    setTimeout(function() {
                        btn.prop('disabled', false);
                        btn.html('Gửi đánh giá');
                    }, 1500);
                }
            });
        });
    });
    </script>
}
